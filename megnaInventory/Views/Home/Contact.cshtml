@{
    ViewData["Title"] = "Contact Information";
}

<section class="section-padding bg-light" style="min-height: 70vh;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Contact Information</h2>
            <p class="text-muted lead">Get in touch with Meghna Group of Industries.</p>
        </div>

        <div class="row g-4 p-4 mt-2">
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow border-0" style="border-radius: 12px; transition: transform 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-building fa-3x mb-3" style="color: #002c5f;"></i>
                        <h4 class="card-title font-weight-bold" style="color: #002c5f;">Head Office</h4>
                        <p class="card-text text-muted mt-3">
                            <strong>Fresh Villa</strong><br />
                            House # 15, Road # 34<br />
                            Gulshan-1 Dhaka-1212, Bangladesh
                        </p>
                        <hr>
                        <p class="mb-1"><i class="fas fa-phone me-2 text-primary"></i> +880-9666777055</p>
                        <p class="mb-1"><i class="fas fa-fax me-2 text-primary"></i> +880 2222289361</p>
                        <p><i class="fas fa-envelope me-2 text-primary"></i> <a href="mailto:info@mgi.org">info@mgi.org</a></p>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow border-0" style="border-radius: 12px; transition: transform 0.3s ease;">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-store fa-3x mb-3" style="color: #002c5f;"></i>
                        <h4 class="card-title font-weight-bold" style="color: #002c5f;">FMCG Office</h4>
                        <p class="card-text text-muted mt-3">
                            <strong>Fresh House</strong><br />
                            House # 23, Road # 24<br />
                            Gulshan # 2, Dhaka - 1212
                        </p>
                        <hr>
                        <p class="mb-1"><i class="fas fa-phone me-2 text-primary"></i> +880 9666777055</p>
                        <p><i class="fas fa-envelope me-2 text-primary"></i> <a href="mailto:info@mgi.org">info@mgi.org</a></p>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow border-0" style="border-radius: 12px; transition: transform 0.3s ease;">
                    <div class="card-body p-4 text-center">
