@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container" style="padding-top: 120px; padding-bottom: 100px; min-height: 70vh;">
    <h1 style="color: #002c5f; font-weight: 800; text-transform: uppercase;">@ViewData["Title"]</h1>
    <hr style="width: 50px; border: 2px solid #0056b3; opacity: 1; margin-bottom: 30px;" />

    <p class="lead text-muted">Use this page to detail your site's privacy policy for the Meghna Group of Industries tracking and inventory system.</p>
    
    <div class="mt-4">
        <h4>1. Information Collection</h4>
        <p class="text-secondary">We log data specifically related to inventory movements, user access logs, and operational events.</p>
        
        <h4 class="mt-4">2. Usage</h4>
        <p class="text-secondary">This platform data is strictly to be utilized in conformity with Meghna Group of Industries corporate standards.</p>
    </div>
</div>
