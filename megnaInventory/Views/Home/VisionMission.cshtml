@{
    ViewData["Title"] = "Vision, Mission & Values";
}

<section class="section-padding bg-white" style="min-height: 70vh;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Vision, Mission & Values</h2>
            <p class="text-muted">The core principles guiding the Meghna Group of Industries.</p>
        </div>

        <div class="row p-4 justify-content-center">
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-eye fa-3x mb-3" style="color: #002c5f;"></i>
                        <h3 class="card-title font-weight-bold" style="color: #002c5f;">VISION</h3>
                        <p class="card-text lead mt-3">To be Bangladesh’s most admired and progressive global conglomerate.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-bullseye fa-3x mb-3" style="color: #d11241;"></i>
                        <h3 class="card-title font-weight-bold" style="color: #d11241;">MISSION</h3>
                        <p class="card-text lead mt-3">Delighting our customers and maximizing value by innovative solutions, inspired employees, adaptation of technological advancements and living in harmony with environment.</p>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-12 mt-4">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="fas fa-gem fa-3x mb-3" style="color: #002c5f;"></i>
                            <h3 class="font-weight-bold" style="color: #002c5f;">VALUES</h3>
                        </div>
                        <div class="row text-center lead font-weight-bold mt-4">
                            <div class="col-md-4 mb-3"><i class="fas fa-check-circle text-success me-2"></i> Integrity</div>
                            <div class="col-md-4 mb-3"><i class="fas fa-check-circle text-success me-2"></i> Respect</div>
                            <div class="col-md-4 mb-3"><i class="fas fa-check-circle text-success me-2"></i> Keeping Promises</div>
                            <div class="col-md-6 mb-3"><i class="fas fa-check-circle text-success me-2"></i> Customer Focus</div>
                            <div class="col-md-6 mb-3"><i class="fas fa-check-circle text-success me-2"></i> Team Work</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
