@model List<megnaInventory.Controllers.UserViewModel>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0 text-dark"><i class="fas fa-chart-line me-2 text-primary"></i>Overview</h3>
            <div class="text-muted small">
                <i class="fas fa-calendar-alt me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats Row 1 -->
<div class="row g-4 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #004b93 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary-light p-3 me-3 text-primary">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Users</h6>
                        <h2 class="fw-bold mb-0">@Model.Count</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #198754 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success-light p-3 me-3 text-success">
                        <i class="fas fa-check-circle fa-2x"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Approved Users</h6>
                        <h2 class="fw-bold mb-0">@Model.Count(u => u.IsApproved)</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #ffc107 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning-light p-3 me-3 text-warning">
                        <i class="fas fa-clock fa-2x"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Pending Approvals</h6>
                        <h2 class="fw-bold mb-0">@Model.Count(u => !u.IsApproved)</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100 stat-card" style="border-left: 5px solid #6366f1 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-indigo-light p-3 me-3 text-indigo">
                        <i class="fas fa-boxes fa-2x"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Inventory Items</h6>
                        <h2 class="fw-bold mb-0">7</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Role Distribution Row 2 -->
<div class="row">
    <div class="col-12 mb-3">
        <h4 class="fw-bold"><i class="fas fa-user-tag me-2 text-secondary"></i>Role Distribution</h4>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-xl-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 role-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Managers</h5>
                    <span class="badge bg-info p-2 rounded-circle">
                         <i class="fas fa-user-tie"></i>
                    </span>
                </div>
                <h2 class="fw-bold">@Model.Count(u => u.Roles.Contains("Inventory Manager"))</h2>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-info" style="width: @(Model.Count > 0 ? (Model.Count(u => u.Roles.Contains("Inventory Manager")) * 100 / Model.Count) : 0)%"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 role-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Sales Persons</h5>
                    <span class="badge bg-secondary p-2 rounded-circle">
                         <i class="fas fa-shopping-cart"></i>
                    </span>
                </div>
                <h2 class="fw-bold">@Model.Count(u => u.Roles.Contains("Sales Person"))</h2>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-secondary" style="width: @(Model.Count > 0 ? (Model.Count(u => u.Roles.Contains("Sales Person")) * 100 / Model.Count) : 0)%"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-sm-12">
        <div class="card border-0 shadow-sm h-100 role-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Suppliers</h5>
                    <span class="badge bg-dark p-2 rounded-circle">
                         <i class="fas fa-truck"></i>
                    </span>
                </div>
                <h2 class="fw-bold">@Model.Count(u => u.Roles.Contains("Supplier"))</h2>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-dark" style="width: @(Model.Count > 0 ? (Model.Count(u => u.Roles.Contains("Supplier")) * 100 / Model.Count) : 0)%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Other Activity Placeholder -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold">Recent System Activity</h5>
            </div>
            <div class="card-body py-5 text-center">
                <i class="fas fa-history fa-3x text-muted mb-3"></i>
                <p class="text-muted">No recent activity logs available to show yet.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-light { background-color: rgba(0, 75, 147, 0.1); }
    .bg-success-light { background-color: rgba(25, 135, 84, 0.1); }
    .bg-warning-light { background-color: rgba(255, 193, 7, 0.1); }
    .bg-danger-light { background-color: rgba(220, 53, 69, 0.1); }
    .bg-indigo-light { background-color: rgba(99, 102, 241, 0.1); }
    .text-indigo { color: #6366f1; }
    
    .stat-card {
        transition: transform 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
    }
    
    .role-card {
        border-top: 4px solid #dee2e6;
    }
</style>
