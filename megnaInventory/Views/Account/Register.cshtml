@model megnaInventory.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Register New Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <!-- Logo Section -->
                    <div class="text-center mb-4">
                        <img src="~/img/logo.png" alt="MGI Logo" style="max-height: 80px;" />
                        <h2 class="mt-3 fw-bold" style="color: #002c5f;">Create Account</h2>
                        <p class="text-muted">Register for system access</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="mb-3">
                            <i class="fas fa-exclamation-circle me-2 text-danger"></i>
                            <span asp-validation-summary="All" class="text-danger"></span>
                        </div>
                    }

                    <form method="post" asp-action="Register">

                        <div class="form-floating mb-3">
                            <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                            <label asp-for="FullName"><i class="fas fa-user me-2"></i>Full Name</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email"><i class="fas fa-envelope me-2"></i>Email Address</label>
                        </div>

                        <div class="form-floating mb-3">
                            @{
                                var roles = new List<string> { "Inventory Manager", "Sales Person", "Supplier" };
                            }
                            <select asp-for="Role" class="form-select" asp-items="new SelectList(roles)">
                                <option value="">-- Select Role --</option>
                            </select>
                            <label asp-for="Role"><i class="fas fa-users me-2"></i>Select Role</label>
                            <small class="text-muted mt-1 d-block">
                                <i class="fas fa-info-circle me-1"></i>
                                If your selected role doesn't exist, it will be created automatically.
                            </small>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control" placeholder="Password" />
                            <label asp-for="Password"><i class="fas fa-lock me-2"></i>Password</label>
                            <small class="text-muted mt-1 d-block">
                                Minimum 6 characters
                            </small>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" />
                            <label asp-for="ConfirmPassword"><i class="fas fa-lock me-2"></i>Confirm Password</label>
                        </div>

                        <button type="submit" class="btn btn-primary-mgi w-100 py-2 fw-bold" style="font-size: 1.1rem;">
                            <i class="fas fa-user-plus me-2"></i>Register
                        </button>
                    </form>

                    <hr class="my-4" />

                    <div class="alert alert-info mb-4" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Important:</strong> After registration, your account needs admin approval. You'll receive an email once approved.
                    </div>

                    <div class="text-center">
                        <p class="mb-0 text-muted">
                            Already have an account? 
                            <a asp-action="Login" class="fw-bold text-decoration-none">Login here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .card {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    }
    
    .form-control:focus,
    .form-select:focus {
        border-color: #0076c8;
        box-shadow: 0 0 0 0.2rem rgba(0, 118, 200, 0.25);
    }
    
    .btn-primary-mgi {
        background: linear-gradient(135deg, #004b93 0%, #0076c8 100%);
        border: none;
        transition: all 0.3s ease;
    }
    
    .btn-primary-mgi:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 75, 147, 0.3);
    }
    
    .form-select {
        appearance: auto;
    }
</style>
