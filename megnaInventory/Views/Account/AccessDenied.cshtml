@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <i class="fas fa-lock fa-5x text-danger mb-4"></i>
                    <h2 class="fw-bold text-danger">Access Denied</h2>
                    <p class="lead text-muted">You do not have permission to access this resource.</p>
                    <hr />
                    <p class="text-muted small">
                        If you believe this is an error, please contact your administrator.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary-mgi mt-3">
                        <i class="fas fa-home me-2"></i>Go to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    }
    
    .btn-primary-mgi {
        background: linear-gradient(135deg, #004b93 0%, #0076c8 100%);
        border: none;
    }
    
    .btn-primary-mgi:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 75, 147, 0.3);
    }
</style>
